{
  "manifest_version": 3,
  "name": "xtap-pool",
  "version": "0.18.0",
  "description": "Passively captures tweets from X/Twitter as you browse and pools them with friends via a private Hugging Face Space",
  "permissions": ["storage", "nativeMessaging", "alarms", "unlimitedStorage"],
  "host_permissions": [
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "http://127.0.0.1/*",
    "https://*.hf.space/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["content-main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["content-bridge.js"],
      "world": "ISOLATED",
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.hf.space/*"],
      "js": ["pool-connect.js"],
      "world": "ISOLATED",
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
